# ─────────────────────────────────────────────────────
# Discord Bot Settings
# ─────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=DISCORD_TOKEN_HERE
# ─────────────────────────────────────────────────────
# Plex Settings
# ─────────────────────────────────────────────────────

# Full URL to your Plex server — include port (usually 32400)
# Examples:
#   Local:   http://192.168.1.100:32400
#   Remote:  https://your-domain.com:32400
PLEX_URL=http://localhost:32400

# Your Plex authentication token
# Find it at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=PLEX_TOKEN_HERE
